---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import NewsCard from '../components/NewsCard.astro';
import { getNewsPosts, resolveSupabaseEnv } from '../lib/supabase';
import { resolveSiteLinks } from '../lib/links';

const supabaseEnv = resolveSupabaseEnv(Astro.locals);
const { discordUrl } = resolveSiteLinks(Astro.locals);

let latestNews: Awaited<ReturnType<typeof getNewsPosts>> = [];
try {
  latestNews = await getNewsPosts(supabaseEnv, 3);
} catch (err) {
  // Supabase not configured yet / unreachable at build time — render the
  // page gracefully instead of failing the whole request.
  console.error('Failed to load homepage data:', err);
}

// Cache this on Cloudflare's edge for a minute so most visits are served
// instantly, while still picking up Supabase edits within ~60s.
Astro.response.headers.set('Cache-Control', 'public, s-maxage=60, stale-while-revalidate=300');
---

<Layout title="Home">
  <section class="relative overflow-hidden px-6 pb-24 pt-28 sm:pt-36">
    <!--
      Homepage hero background image. Drop the file at
      public/images/hero-bg.jpg (see README for exact dimensions/format
      guidance). The dark gradient overlay on top keeps the white headline
      text readable regardless of what's in the photo; the radial glow is
      layered above the photo for a bit of the old effect's depth.
    -->
    <div
      class="pointer-events-none absolute inset-0 -z-20 bg-cover bg-center"
      style="background-image: url('/images/hero-bg.jpg')"
    >
    </div>
    <div class="pointer-events-none absolute inset-0 -z-10 bg-brand-ink/70"></div>
    <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(circle_at_50%_-10%,rgba(67,105,245,0.25),transparent_60%)]"></div>
    <div class="mx-auto max-w-4xl text-center">
      <p class="reveal font-display text-sm uppercase tracking-[0.3em] text-brand-tertiary">Season 18 · Now Racing</p>
      <h1 class="reveal mt-4 font-display text-5xl leading-[0.95] sm:text-7xl" style="transition-delay: 80ms">
        Alpha Touring<br />Challenge
      </h1>
      <p class="reveal mt-6 text-lg text-white/70" style="transition-delay: 160ms">
        The premier North American touring car series on iRacing.
      </p>
      <div class="reveal mt-10 flex flex-wrap items-center justify-center gap-4" style="transition-delay: 240ms">
        <a
          href={discordUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-full bg-brand-primary px-8 py-3 font-semibold transition hover:brightness-110"
        >
          Sign Up
        </a>
      </div>
    </div>
  </section>

  {latestNews.length > 0 && (
    <section class="mx-auto max-w-6xl px-6 pb-24">
      <div class="mb-8 flex items-end justify-between">
        <h2 class="font-display text-3xl">Latest News</h2>
        <a href="/news" class="text-sm text-white/60 hover:text-white">View all &rarr;</a>
      </div>
      <NewsCard post={latestNews[0]} index={0} featured />
      {latestNews.length > 1 && (
        <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {latestNews.slice(1).map((post, i) => <NewsCard post={post} index={i + 1} />)}
        </div>
      )}
    </section>
  )}
</Layout>
