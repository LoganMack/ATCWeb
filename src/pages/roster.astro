---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import DriverRow from '../components/DriverRow.astro';
import { getDrivers, resolveSupabaseEnv } from '../lib/supabase';

const supabaseEnv = resolveSupabaseEnv(Astro.locals);

let drivers: Awaited<ReturnType<typeof getDrivers>> = [];
let loadError = false;
try {
  drivers = await getDrivers(supabaseEnv);
} catch (err) {
  console.error('Failed to load drivers:', err);
  loadError = true;
}

Astro.response.headers.set('Cache-Control', 'public, s-maxage=60, stale-while-revalidate=300');

const classes = ['All', 'Alpha', 'Gamma', 'Delta'];
// "Active" here is a quick filter, not the literal driver_statuses.name —
// it covers Active, Veteran, and New (i.e. everyone who isn't Inactive).
// See ACTIVE_STATUSES in the filter script below.
const statuses = ['Active', 'Inactive', 'All'];
---

<Layout title="Roster" description="The current Alpha Touring Challenge driver roster.">
  <section class="mx-auto max-w-6xl px-6 pb-24 pt-28 sm:pt-36">
    <h1 class="reveal font-display text-5xl">Driver Roster</h1>
    <p class="reveal mt-3 text-white/60" style="transition-delay: 80ms">
      {drivers.length} drivers currently on the books.
    </p>

    {loadError && (
      <p class="mt-8 rounded-xl border border-brand-pink/30 bg-brand-pink/10 p-4 text-sm text-white/80">
        Couldn't load the roster right now — check that PUBLIC_SUPABASE_URL and PUBLIC_SUPABASE_ANON_KEY are set.
      </p>
    )}

    <div class="reveal mt-10 flex flex-wrap gap-6" style="transition-delay: 120ms">
      <div class="flex flex-wrap gap-2" data-filter-group="class">
        {classes.map((c) => (
          <button
            type="button"
            data-filter-value={c}
            class="rounded-full px-4 py-1.5 text-sm font-semibold ring-1 ring-white/15 transition data-[active=true]:bg-white data-[active=true]:text-brand-ink"
            data-active={c === 'All' ? 'true' : 'false'}
          >
            {c}
          </button>
        ))}
      </div>
      <div class="flex flex-wrap gap-2" data-filter-group="status">
        {statuses.map((s) => (
          <button
            type="button"
            data-filter-value={s}
            class="rounded-full px-4 py-1.5 text-sm font-semibold ring-1 ring-white/15 transition data-[active=true]:bg-white data-[active=true]:text-brand-ink"
            data-active={s === 'Active' ? 'true' : 'false'}
          >
            {s}
          </button>
        ))}
      </div>
    </div>

    <!--
      A dense table instead of a card grid — maximizes how many drivers are
      visible on screen at once. Less critical columns progressively drop
      off on narrower viewports (car/starts/seasons at lg, status at md,
      team name at sm) rather than shrinking everything down to unreadable.
    -->
    <!--
      Deliberately NOT using the .reveal scroll-in animation here — with a
      roster this long, the table starts at or below the fold on most
      screens, and IntersectionObserver (threshold 0.15) never fires until
      it's scrolled into view. That made the whole table look like it
      wasn't loading. It should just be visible immediately.
    -->
    <div class="mt-8 overflow-x-auto rounded-2xl border border-white/10">
      <table class="w-full border-collapse">
        <thead>
          <tr class="border-b border-white/10 text-left text-xs uppercase tracking-wide text-white/40">
            <th class="py-3 pl-4 pr-2 font-medium">#</th>
            <th class="py-3 pr-3 font-medium">Driver</th>
            <th class="hidden py-3 pr-3 font-medium sm:table-cell">Team</th>
            <th class="py-3 pr-3 font-medium">Class</th>
            <th class="hidden py-3 pr-3 font-medium md:table-cell">Status</th>
            <th class="hidden py-3 pr-3 font-medium lg:table-cell">Car</th>
            <th class="hidden py-3 pr-3 text-center font-medium lg:table-cell">Starts</th>
            <th class="hidden py-3 pr-3 text-center font-medium lg:table-cell">Seasons</th>
            <th class="py-3 pr-4 text-center font-medium">Penalty Pts</th>
          </tr>
        </thead>
        <tbody id="roster-body">
          {drivers.map((driver, i) => <DriverRow driver={driver} index={i} />)}
        </tbody>
      </table>
    </div>
  </section>

  <script>
    // "Active" is a quick filter, not a literal driver_statuses.name match —
    // it covers Active, Veteran, and New (everyone who isn't Inactive).
    const ACTIVE_STATUSES = ['Active', 'Veteran', 'New'];

    function initRosterFilters() {
      const body = document.getElementById('roster-body');
      if (!body) return;

      // Defaults match what's marked data-active="true" in the markup:
      // all classes, active-ish drivers only.
      const state: Record<string, string> = { class: 'All', status: 'Active' };

      function statusMatches(rowStatus: string | undefined) {
        if (state.status === 'All') return true;
        if (state.status === 'Active') return ACTIVE_STATUSES.includes(rowStatus ?? '');
        return rowStatus === state.status;
      }

      function applyFilters() {
        const rows = body!.querySelectorAll<HTMLElement>('[data-class]');
        rows.forEach((row) => {
          const classMatch = state.class === 'All' || row.dataset.class === state.class;
          row.style.display = classMatch && statusMatches(row.dataset.status) ? '' : 'none';
        });
      }

      document.querySelectorAll<HTMLElement>('[data-filter-group]').forEach((group) => {
        const key = group.dataset.filterGroup!;
        group.querySelectorAll<HTMLButtonElement>('button').forEach((btn) => {
          btn.addEventListener('click', () => {
            state[key] = btn.dataset.filterValue!;
            group.querySelectorAll<HTMLButtonElement>('button').forEach((b) => {
              b.dataset.active = String(b === btn);
            });
            applyFilters();
          });
        });
      });

      // Apply the default filter state immediately — otherwise every row is
      // visible (no inline style yet) until the visitor clicks a button.
      applyFilters();
    }

    document.addEventListener('astro:page-load', initRosterFilters);
  </script>
</Layout>
