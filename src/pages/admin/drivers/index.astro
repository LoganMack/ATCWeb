---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { resolveSupabaseEnv, getDrivers } from '../../../lib/supabase';

const supabaseEnv = resolveSupabaseEnv(Astro.locals);

let drivers: Awaited<ReturnType<typeof getDrivers>> = [];
let loadError = false;
try {
  drivers = await getDrivers(supabaseEnv);
} catch (err) {
  console.error('Failed to load drivers for admin:', err);
  loadError = true;
}
---

<AdminLayout title="Drivers">
  <div class="reveal flex items-center justify-between">
    <h1 class="font-display text-4xl">Drivers</h1>
    <a href="/admin/drivers/new" class="rounded-full bg-brand-primary px-5 py-2.5 font-semibold transition hover:brightness-110">
      New Driver
    </a>
  </div>

  {loadError && (
    <p class="mt-8 rounded-xl border border-brand-pink/30 bg-brand-pink/10 p-4 text-sm text-white/80">
      Couldn't load drivers.
    </p>
  )}

  <div class="reveal mt-8 divide-y divide-white/10 rounded-2xl border border-white/10" style="transition-delay: 80ms">
    {drivers.map((driver) => (
      <a
        href={`/admin/drivers/${driver.id}`}
        class="flex flex-wrap items-center justify-between gap-2 px-6 py-3 transition hover:bg-white/[0.03]"
      >
        <div class="flex items-center gap-4">
          <span class="w-10 font-display text-xl text-white/60">
            {driver.car_number !== null ? `#${driver.car_number}` : '—'}
          </span>
          <div>
            <p class="font-semibold">{driver.name}</p>
            <p class="text-sm text-white/50">{driver.teams?.name ?? 'No team'}</p>
          </div>
        </div>
        <div class="flex items-center gap-3 text-sm text-white/60">
          <span>{driver.driver_classes?.name}</span>
          <span>{driver.driver_statuses?.name}</span>
        </div>
      </a>
    ))}
  </div>
</AdminLayout>
