---
import { ViewTransitions } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Alpha Touring Challenge — an online touring car racing series.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title} · Alpha Touring Challenge</title>

    <!--
      Fonts: Teko (display/headlines) + Roboto (body), loaded from Google
      Fonts. This needs no npm package and no local font files, so it works
      as soon as this deploys — see the licensing note in the README for why
      Teko stands in for Cuatra for now. If you'd rather self-host for
      privacy/perf reasons later, swap this for Fontsource packages.
    -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&family=Teko:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <ViewTransitions />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
    <script src="../scripts/reveal.ts"></script>
  </body>
</html>
