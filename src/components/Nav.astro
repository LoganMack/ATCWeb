---
const discordUrl = import.meta.env.PUBLIC_DISCORD_URL;
const redbubbleUrl = import.meta.env.PUBLIC_REDBUBBLE_URL;

const links = [
  { href: '/', label: 'Home' },
  { href: '/roster', label: 'Roster' },
  { href: '/news', label: 'News' },
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-brand-ink/80 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center" transition:name="site-logo">
      <img src="/logos/atc18-white.png" alt="Alpha Touring Challenge" class="h-9 w-auto sm:h-11" />
    </a>

    <nav class="hidden items-center gap-8 font-display text-lg uppercase tracking-widest sm:flex">
      {links.map((link) => (
        <a href={link.href} class="text-white/80 transition hover:text-white">
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={discordUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full bg-white/5 px-4 py-2 text-sm font-semibold text-white/90 ring-1 ring-white/10 transition hover:bg-white/10 hover:ring-white/20"
      >
        Discord
      </a>
      <a
        href={redbubbleUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full bg-brand-pink px-4 py-2 text-sm font-semibold text-white transition hover:brightness-110"
      >
        Merch
      </a>
    </div>
  </div>
</header>
